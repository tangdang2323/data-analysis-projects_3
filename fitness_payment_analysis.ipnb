  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "28c43b7f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "800.0 1800.0 7200.0 19519.99999999989\n"
     ]
    }
   ],
   "source": [
    "q1 = np.percentile(pay_lst, 25)\n",
    "q2 = np.percentile(pay_lst, 50)\n",
    "q3 = np.percentile(pay_lst, 75)\n",
    "p95 = np.percentile(pay_lst, 95)\n",
    "print(q1, q2, q3, p95)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "173346c1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "-8800.0\n",
      "16800.0\n"
     ]
    }
   ],
   "source": [
    "iqr = q3-q1\n",
    "lower_bound = q1-1.5*iqr\n",
    "upper_bound = q3+1.5*iqr\n",
    "print(lower_bound)\n",
    "print(upper_bound)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "d8bdc7fe",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Новое средее значение 3645.71\n"
     ]
    }
   ],
   "source": [
    "sum_pay = 0\n",
    "cnt_pay = 0\n",
    "for i in pay_lst:\n",
    "    if (i<upper_bound) and (i>lower_bound):\n",
    "        sum_pay +=i\n",
    "        cnt_pay +=1\n",
    "avg_pay = sum_pay/cnt_pay\n",
    "print(f\"Новое средее значение {round(avg_pay, 2)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f8b4201c",
   "metadata": {},
   "source": [
    "<image src=\"/IQR_range.jpg\" alt=\"Описание изображения\">"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "3fe6cc99",
   "metadata": {},
   "source": [
    "# Задача 5.\n",
    "Преобразуем код из задачи 4 в функцию, которая принимает на вход только список и возвращает среднее значение рассчитанное после исключения выбросов"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "62e2051c",
   "metadata": {},
   "outputs": [],
   "source": [
    "def calc_avg_adv(lst):\n",
    "    try:\n",
    "        q1 = np.percentile(lst, 25)\n",
    "        q3 = np.percentile(lst, 75)\n",
    "        iqr = q3-q1\n",
    "        lower_bound = q1-1.5*iqr\n",
    "        upper_bound = q3+1.5*iqr\n",
    "        sum_pay = 0\n",
    "        cnt_pay = 0\n",
    "        for i in lst:\n",
    "            if (i<upper_bound) and (i>lower_bound):\n",
    "                sum_pay +=i\n",
    "                cnt_pay +=1\n",
    "        avg_pay = sum_pay/cnt_pay\n",
    "        return round(avg_pay, 2)\n",
    "    except:\n",
    "        print('Список не должен содержать нечиcловых значений или быть пустым')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "6f35c95f",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "3645.71"
      ]
     },
     "execution_count": 14,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "calc_avg_adv(pay_lst)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "e303c013",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Список не должен содержать нечиcловых значений или быть пустым\n"
     ]
    }
   ],
   "source": [
    "lst1 = []\n",
    "calc_avg_adv(lst1)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "52951909",
   "metadata": {},
   "source": [
    "### Задача 6.\n",
    "У нас изменились исходные данные - теперь это словарь с платежами клиентов по месяцам. Нужно найти среднее значение для каждого месяца\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "5b8a1258",
   "metadata": {},
   "outputs": [],
   "source": [
    "pay_month =  {'jan':[6400, 8000, 18000, 3600, 36000, 1600], 'feb': [1600, 800, 800, 3200, 5800, 5600],\\\n",
    "              'march': [1600, 800, 8000, 18000, 9000, 3200]}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "b778e778",
   "metadata": {},
   "outputs": [],
   "source": [
    "avg_pay = {}\n",
    "for mon in pay_month.keys():\n",
    "    pay = pay_month[mon]\n",
    "    avg = sum(pay)/len(pay)\n",
    "    avg_pay[mon] = avg"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "2c14991c",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "{'jan': 12266.666666666666,\n",
       " 'feb': 2966.6666666666665,\n",
       " 'march': 6766.666666666667}"
      ]
     },
     "execution_count": 18,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "avg_pay"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "7c39c9d3",
   "metadata": {},
   "outputs": [],
   "source": [
    "def calc_avg_dict(mydict):\n",
    "    avg_pay = {}\n",
    "    for mon in mydict.keys():\n",
    "        try:\n",
    "            pay = mydict[mon]\n",
    "            avg = sum(pay)/len(pay)\n",
    "            avg_pay[mon] = avg\n",
    "        except:\n",
    "            avg_pay[mon] = None\n",
    "    return avg_pay"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "7a7a10b3",
   "metadata": {},
   "outputs": [],
   "source": [
    "pay_month1 =  {'jan':[6400, 8000, 18000, 3600, 36000, 1600], 'feb': [1600, 800, 800, 3200, 5800, 5600],\\\n",
    "              'march': [1600, 800, 8000, 18000, 9000, 3200], 'april': []}"
   ]
  },
